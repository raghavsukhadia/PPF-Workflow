{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "dist/public",
    "rewrites": [
        {
            "source": "/api/users(.*)",
            "destination": "/api/users$1"
        },
        {
            "source": "/api/packages(.*)",
            "destination": "/api/packages$1"
        },
        {
            "source": "/api/jobs/summary",
            "destination": "/api/jobs-summary"
        },
        {
            "source": "/api/jobs/delivered",
            "destination": "/api/jobs-delivered"
        },
        {
            "source": "/api/jobs/([^/]+)/issues",
            "destination": "/api/jobs-id-issues?id=$1"
        },
        {
            "source": "/api/jobs/([^/]+)/ppf-usage",
            "destination": "/api/jobs-id-ppf-usage?id=$1"
        },
        {
            "source": "/api/jobs/([^/]+)/deliver",
            "destination": "/api/jobs-id-deliver?id=$1"
        },
        {
            "source": "/api/jobs/([^/]+)",
            "destination": "/api/jobs-id?id=$1"
        },
        {
            "source": "/api/jobs(.*)",
            "destination": "/api/jobs$1"
        },
        {
            "source": "/api/ppf-products/([^/]+)",
            "destination": "/api/ppf-products-id?id=$1"
        },
        {
            "source": "/api/ppf-products",
            "destination": "/api/ppf-products"
        },
        {
            "source": "/api/ppf-rolls/([^/]+)",
            "destination": "/api/ppf-rolls-id?id=$1"
        },
        {
            "source": "/api/ppf-rolls",
            "destination": "/api/ppf-rolls"
        },
        {
            "source": "/api/issues/([^/]+)",
            "destination": "/api/issues-id?id=$1"
        },
        {
            "source": "/api/ppf-usage/([^/]+)",
            "destination": "/api/ppf-usage-id?id=$1"
        },
        {
            "source": "/api/diagnostic",
            "destination": "/api/diagnostic"
        },
        {
            "source": "/api/((?!users|packages|diagnostic|ppf-products|ppf-rolls|jobs).*)",
            "destination": "/api/index"
        },
        {
            "source": "/assets/(.*)",
            "destination": "/assets/$1"
        },
        {
            "source": "/logo.png",
            "destination": "/logo.png"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "cleanUrls": false,
    "trailingSlash": false
}